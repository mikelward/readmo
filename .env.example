# Readmo client (Vite) environment.
#
# Copy to `.env.local` and fill in from Supabase → Project Settings → API.
# Both values are PUBLIC (RLS-gated) and safe to ship to the browser.
#
# SECURITY: never put the service-role key or any OAuth client secret in a
# VITE_* variable — anything prefixed VITE_ is bundled into the client. Those
# secrets belong only in the Edge Functions environment (see SETUP.md §5).

# Project URL, e.g. https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# anon public key
VITE_SUPABASE_ANON_KEY=
