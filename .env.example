# Readmo client (Vite) environment.
#
# Copy to `.env.local` and fill in the project URL + anon/publishable key from
# the Supabase dashboard (Connect button, or Project Settings → Data API / API
# Keys). Both values are PUBLIC (RLS-gated) and safe to ship to the browser.
#
# Deploying via the Supabase↔Vercel integration? You don't need these — the app
# also reads the integration's public NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_ANON_KEY (or NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY) names.
#
# SECURITY: never put the service-role/secret key or any OAuth client secret in a
# VITE_* (or NEXT_PUBLIC_*) variable — those prefixes are bundled into the
# client. Secrets belong only in the Edge Functions environment (see SETUP.md §5).

# Project URL, e.g. https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# anon public key
VITE_SUPABASE_ANON_KEY=
