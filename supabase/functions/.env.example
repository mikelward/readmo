# Edge Functions environment (SERVER-ONLY secrets).
#
# These belong to the Supabase Functions runtime, NOT the Vite client. Never put
# any of these in a VITE_*/NEXT_PUBLIC_* variable — see SETUP.md §5.
#
# In production set the custom (non-SUPABASE_) names with:
#   supabase secrets set SMTP_HOST=… SMTP_PORT=… SMTP_USERNAME=… SMTP_PASSWORD=…
# For LOCAL `supabase functions serve`, copy this file to an untracked
# `supabase/functions/.env` and also add SUPABASE_URL / SUPABASE_ANON_KEY /
# SUPABASE_SERVICE_ROLE_KEY (auto-injected in production, needed by hand locally).

# --- notify-signup: SMTP for the "new user signed up" alert email ---
# SMTP relay host, e.g. smtp.fastmail.com / smtp.gmail.com / email-smtp.<region>.amazonaws.com
SMTP_HOST=
# 465 = implicit TLS (default), 587 = STARTTLS. SMTP_TLS overrides if set (true/false).
SMTP_PORT=465
SMTP_TLS=
# SMTP login (for Gmail use an App Password, not your account password).
SMTP_USERNAME=
SMTP_PASSWORD=
# Sender address shown on the alert. Defaults to SMTP_USERNAME if unset.
SMTP_FROM=
# Where signup alerts are delivered. Defaults to mikel@mikelward.com if unset.
SIGNUP_NOTIFY_TO=
